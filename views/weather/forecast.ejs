<body>
    <header>
      <h1>5-Day Weather Forecast for <%= city %></h1>
    </header>
    <main>
      <section>
        <% Object.keys(groupedForecast).forEach(date => { %>
        <div>
          <h2><%= date %></h2>
          <div>
            <% groupedForecast[date].forEach(item => { %>
            <div>
            <img src="http://openweathermap.org/img/wn/<%= item.icon %>@2x.png" alt="Weather icon showing <%= item.description %>"/>
              <p><strong>Time:</strong> <%= item.time %></p>
              <p><strong>Temp:</strong> <%= item.temp %>°F</p>
              <p><strong>Condition:</strong> <%= item.description %></p>
            </div>
            <% }) %>
          </div>
        </div>
        <% }) %>
      </section>
      <a href="/">Back to Home</a>
    </main>
  </body>